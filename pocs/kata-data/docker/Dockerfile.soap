FROM rust:1.82-slim as builder
WORKDIR /app
COPY Cargo.toml Cargo.lock ./
COPY mock-soap ./mock-soap
COPY src ./src
RUN cargo build --release --bin mock-soap

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y ca-certificates curl && rm -rf /var/lib/apt/lists/*
COPY --from=builder /app/target/release/mock-soap /usr/local/bin/mock-soap
EXPOSE 8081
CMD ["mock-soap"]
